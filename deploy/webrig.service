[Unit]
Description=WebRig Web Interface
After=network.target rigctld.service
Wants=rigctld.service

[Service]
Type=simple
WorkingDirectory=/root/.openclaw/workspace/webrig
ExecStart=/root/.openclaw/workspace/webrig/venv/bin/uvicorn backend.main:asgi_app --host 0.0.0.0 --port 8081
Restart=always
RestartSec=3
Environment=LOGLEVEL=INFO

[Install]
WantedBy=multi-user.target
